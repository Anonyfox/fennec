(* The app SHELL (layout): persistent nav + the routed outlet. *)
let make () =
  Head.description "iso router demo";
  Head.og "og:title" "iso shop";
  fun () ->
    <div id="app-root">
      <nav className="nav">
        <a className="nav-home" href=(p "/")>"Home"</a>
        " · "
        <a className="nav-products" href=(p "/products")>"Products"</a>
        " · "
        <a className="nav-admin" href=(ext "/admin")>"Admin ↗"</a>
      </nav>
      (outlet ())
    </div>
