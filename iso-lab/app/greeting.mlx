(* Regular isomorphic resource (Data.string: string payload, no decoder). *)
let make () =
  let g = Data.string "/api/greeting" ~fallback:"…" () in
  fun () ->
    <div className="greeting">
      <p className="msg">(Data.value g)</p>
      <span className="gstatus">(if Data.loading g then " (loading)" else " (ready)")</span>
      <button id="refetch" onClick=(fun () -> Data.refetch g)>"refetch"</button>
    </div>
