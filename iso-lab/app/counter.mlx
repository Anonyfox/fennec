(* LOCAL state = a signal created in setup. [make ()] runs ONCE per instance; the
   returned closure is the render. Two <Counter/> tags => two independent counts. *)
open Iso

let make () =
  let count = signal 0 in
  fun () ->
    <div className="counter">
      <button onClick=(fun () -> update count (fun n -> n - 1))>"−"</button>
      <span className="count">(get count)</span>
      <button onClick=(fun () -> update count (fun n -> n + 1))>"+"</button>
    </div>
