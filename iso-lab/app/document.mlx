(* SERVER-ONLY document shell. Places framework slots; the SSR driver fills them. *)
let make ctx =
  <html lang="en">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1" />
      (Doc.head ctx)
      <style>(Doc.styles ctx)</style>
    </head>
    <body>
      <div id="app">(Doc.outlet ctx)</div>
      (Doc.scripts ctx)
    </body>
  </html>
