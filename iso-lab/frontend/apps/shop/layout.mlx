(* the app's persistent shell: nav + the routed outlet *)
let () = Head.description "iso shop"
let () = Head.og "og:title" "iso shop"
let view =
  <div id="app-root">
    <nav className="nav">
      <a className="nav-home" href=(p "/")>"Home"</a>
      " · "
      <a className="nav-products" href=(p "/products")>"Products"</a>
      " · "
      <a className="nav-admin" href=(ext "/admin")>"Admin ↗"</a>
    </nav>
    (outlet ())
  </div>
