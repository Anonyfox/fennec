let view =
  <div className="todos">
    <button id="add" onClick=(Store.add (Printf.sprintf "item %d" (peek Store.next_id)))>"add todo"</button>
    <ul>
      (each (get Store.todos) (fun (t : Store.todo) ->
         <li key=t.id className="todo">
           t.text
           <button className="rm" onClick=(Store.remove t.id)>"×"</button>
         </li>))
    </ul>
  </div>
