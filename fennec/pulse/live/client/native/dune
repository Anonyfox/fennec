; Native (SSR) implementation of the DDP client: no socket — connect yields an empty live store so
; `find` renders [] on the server. The browser impl connects for real after hydration. Linked into
; the native SSR binary (the default implementation).

(library
 (name fennec_pulse_live_client_native)
 (public_name fennec.pulse.live.client.native)
 (implements fennec.pulse.live.client)
 (modes byte native)
 (libraries
  fennec.pulse.live
  fennec.fur
  fennec-mongo.bson
  fennec.pulse.method fennec.pulse.collection fennec.pulse.codec)
 (flags
  (:standard -w -a)))
