; Melange (CSR) side of the isomorphic <Head>: the context sink store, the shared
; <Head> component (copied from ../head_component.ml), and the Provider that
; applies the merged head to the live document. Same module name (Fennec_headkit)
; as the native lib, so app code references it identically per target.
(library
 (name fennec_headkit)
 (public_name fennec.headkit_melange)
 (modes melange)
 (flags
  (:standard -w -27-32-33-37-39))
 (libraries fennec.head reason-react melange.js)
 (preprocess
  (pps melange.ppx reason-react-ppx)))

(copy_files#
 (files ../head_component.ml))
