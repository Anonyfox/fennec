; The universal router — native (SSR) side. Matches paths to pages, renders them
; through the headkit context, wraps in a layout to a full document.
(library
 (name fennec_router)
 (public_name fennec.router)
 (modes native)
 (flags
  (:standard -w -27-32-33-37-39))
 (libraries fennec.matcher fennec.head fennec.headkit server-reason-react.react
   server-reason-react.reactDom)
 (preprocess
  (pps server-reason-react.browser_ppx server-reason-react.melange_ppx server-reason-react.ppx)))
