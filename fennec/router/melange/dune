; The universal router — melange (CSR) side. Same route table as native; drives
; client navigation + hydration, applying each page's <Head> to the live document.
(library
 (name fennec_router)
 (public_name fennec.router_melange)
 (modes melange)
 (flags
  (:standard -w -27-32-33-37-39))
 (libraries fennec.matcher fennec.head fennec.headkit_melange reason-react melange.js)
 (preprocess
  (pps melange.ppx reason-react-ppx)))
