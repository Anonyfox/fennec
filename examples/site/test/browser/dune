; Browser suites for `fennec test browser` (needs a system Chrome). Zero-ceremony authoring: drop
; a `*_test.ml` with
;   let%browser "name" = fun page -> page |> goto "/" |> …
; — no main, no Run.main_cli trailer, no edit here. The -linkall library force-links every suite
; module so each registers; the one-line `run` executable is the entry. fennec builds it one-shot
; and runs it PER suite file (--only-file) against that file's own isolated app instance.
; NOT @runtest — so a bare `dune test` never needs Chrome.
(library
 (name site_browser_suites)
 (modules (:standard \ run))
 (libraries fennec-hunt)
 (library_flags (-linkall))
 (preprocess (pps fennec-hunt.ppx)))

(executable
 (name run)
 (modules run)
 (libraries site_browser_suites fennec-hunt))
