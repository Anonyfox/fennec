; System suites for `fennec test system`. Authoring is zero-ceremony: drop a `*_test.ml` with
;   let%system "name" = fun sb -> …
; — no main, no env wiring, no edit here. The library force-links every suite module (-linkall)
; so each one's registrations fire; the one-line `run` executable is the entry point that
; `fennec test system` builds and runs. (`run` is excluded from the library via the module set.)
;
; These drive the REAL `fennec dev`, so they live on their own runner (NOT @runtest) — fennec
; builds it one-shot and runs the artifact directly, never nesting dune.

(library
 (name site_system_suites)
 (modules
  (:standard \ run))
 (libraries fennec-hunt)
 (library_flags (-linkall))
 (preprocess
  (pps fennec-hunt.ppx)))

(executable
 (name run)
 (modules run)
 (libraries site_system_suites fennec-hunt))
