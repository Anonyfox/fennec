; Melange (CSR) compile of the SAME shared app UI. One source of truth in ../ui;
; here it links the melange-side framework libs (router_melange, headkit_melange).
(library
 (name site_ui_melange)
 (public_name fennec-examples.site_ui_melange)
 (modes melange)
 (flags
  (:standard -w -27-32-33-37-39))
