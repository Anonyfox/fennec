; SSR compile of the shared app UI (components, pages, routers). Same sources as
; ui_js/, compiled native via server-reason-react. copy_files# keeps one source
; of truth in ../ui.
(library
 (name site_ui_native)
 (public_name fennec-examples.site_ui)
 (flags
  (:standard -w -27-32-33-37-39))
 (libraries fennec.matcher fennec.head fennec.headkit fennec.router
   server-reason-react.react server-reason-react.reactDom)
 (preprocess
  (pps server-reason-react.browser_ppx server-reason-react.melange_ppx server-reason-react.ppx)))

(copy_files#
 (files ../ui/*))
