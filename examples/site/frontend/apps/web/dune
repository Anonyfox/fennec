; The WEB app as a real, self-contained Dune library — its .mlx (pages, layout, main,
; nested route folders) are REAL modules, so Merlin/LSP works and editing a page
; recompiles only that module. (include_subdirs qualified) maps folders to module
; paths (products/id_.mlx -> Products.Id_). route_gen --glue emits the wiring
; (routes.ml: router + mount; paths.ml: typed paths) that REFERENCES these modules.
(include_subdirs qualified)
(library
 (name web_app)
 (libraries fennec.fur fennec.fur.html site_components site_templates)
 (preprocess (pps fennec.fur.ppx))
 (flags (:standard -w -a -open Fur)))
(rule
 (deps (glob_files_rec *.mlx) %{project_root}/fennec/fur/tools/route_gen.exe)
 (targets routes.ml paths.ml)
 (action (run %{project_root}/fennec/fur/tools/route_gen.exe --glue . .)))
