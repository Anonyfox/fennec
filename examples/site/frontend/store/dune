; Global state store — shared signals (Store.todos, …). Plain .ml, no ppx. Wrapped
; false so the module is just `Store`. Components depend on this lib.

(library
 (name site_store)
 (wrapped false)
 (libraries fennec.fur fennec.pulse.method fennec.pulse.codec fennec.pulse.collection fennec.pulse.live fennec-mongo.bson)
 (preprocess (pps fennec.fur.ppx))   ; the one driver: mlx + tests + collection deriver + DSLs
 (flags
  (:standard -w -a -open Fur)))
