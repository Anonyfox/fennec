; Per-app client bundles — strictly isolated (each bundle boots ONLY its own app).
; The boot entries are GENERATED by `route_gen --boots` from ../frontend/apps/* (no
; hand-written entry files); each app gets one tiny (executable) with (modules <app>)
; so its bundle never links a sibling app's code. The mlx authoring + typed routing
; all live in ../frontend; this dir is pure build glue. Adding an app = a folder under
; ../frontend/apps + its name in the rule targets + a one-line (executable) below.
(rule
 (targets web.ml admin.ml)
 (deps
  (source_tree %{project_root}/examples/site/frontend/apps)
  %{project_root}/fennec/fur/tools/route_gen.exe)
 (action
  (run %{project_root}/fennec/fur/tools/route_gen.exe --boots
   %{project_root}/examples/site/frontend/apps .)))
; the bundles link fennec.live.client.browser — the real-WebSocket implementation of the virtual
; fennec.live.client (the SSR binary uses the native stub); this is how Task_list goes live in-browser
(executable (name web) (modules web) (modes js)
 (libraries web_app fennec.fur.client fennec.live.client.browser) (preprocess (pps js_of_ocaml-ppx)) (flags (:standard -w -a)))
(executable (name admin) (modules admin) (modes js)
 (libraries admin_app fennec.fur.client fennec.live.client.browser) (preprocess (pps js_of_ocaml-ppx)) (flags (:standard -w -a)))
