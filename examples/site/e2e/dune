; Browser tests (needs Chrome): site.ml registers tests; run.ml boots server + browser.
; NOT part of `dune test` (needs a system Chrome); run via ./run.sh.
(executable
 (name run)
 (modules run site)
 (libraries fennec-hunt)
 (link_flags (-linkall)))

; Http tests: spawns `fennec dev`, hits it with typed HTTP requests, asserts responses.
; Dogfoods fennec_hunt.Http — the framework tests itself with its own testing package.
(executable
 (name http_test)
 (modules http_test)
 (libraries fennec-hunt))
