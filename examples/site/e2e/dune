; Browser tests (needs Chrome): site.ml registers tests; run.ml boots server + browser.
; NOT part of `dune test` (needs a system Chrome); run via ./run.sh.
(executable
 (name run)
 (modules run site)
 (libraries fennec-hunt)
 (link_flags (-linkall)))

; Http tests: spawns `fennec dev`, hits it with typed HTTP requests, asserts responses.
; Dogfoods fennec_hunt.Http — the framework tests itself with its own testing package.
(executable
 (name http_test)
 (modules http_test)
 (libraries fennec-hunt))

; TLS proof: a pure-OCaml self-signed HTTPS server (tls_server) + a hunt against it over
; https:// (tls_check). Proves fennec_hunt.Http speaks TLS. Run manually, not in `dune test`.
(executable
 (name tls_check)
 (modules tls_check)
 (libraries fennec-hunt))

(executable
 (name tls_server)
 (modules tls_server)
 (libraries eio eio_main tls tls-eio x509 ptime mirage-crypto-rng.unix))

; I/O e2e proofs (timeout, redirects, chunked) against a tiny pure-Eio probe server.
(executable
 (name probe_server)
 (modules probe_server)
 (libraries eio eio_main))

(executable
 (name probe_check)
 (modules probe_check)
 (libraries fennec-hunt))
