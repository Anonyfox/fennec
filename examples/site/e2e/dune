; Manual fixtures for the fennec-hunt package itself — NOT app tests, and NOT part of
; `fennec test`. The app's own Http and Browser suites now live under test/http/ and
; test/browser/ and run via `fennec test http` / `fennec test browser`.

; TLS proof: a pure-OCaml self-signed HTTPS server (tls_server) + a hunt against it over
; https:// (tls_check). Proves fennec_hunt.Http speaks TLS. Run manually, not in `dune test`.
(executable
 (name tls_check)
 (modules tls_check)
 (libraries fennec-hunt))

(executable
 (name tls_server)
 (modules tls_server)
 (libraries eio eio_main tls tls-eio x509 ptime mirage-crypto-rng.unix))

; I/O e2e proofs (timeout, redirects, chunked) against a tiny pure-Eio probe server.
(executable
 (name probe_server)
 (modules probe_server)
 (libraries eio eio_main))

(executable
 (name probe_check)
 (modules probe_check)
 (libraries fennec-hunt))

; Realtime DDP e2e: a minimal RFC 6455 server (fennec.server's Ws codec) wires a DDP session
; (fennec.pulse.server over fennec.pulse + fennec-mongo) and a fennec-hunt Cdp WebSocket client drives a
; full connect/subscribe/method round-trip, asserting the live server→client push. UNLIKE the
; manual fixtures above, this is self-contained (it runs its own server fiber and exits 0/1), so it
; is a real `(test)` — `dune runtest` (and CI) run it. Exits nonzero on any assertion failure.
(test
 (name realtime_e2e)
 (modules realtime_e2e)
 (libraries eio eio_main fennec.core fennec.server fennec.pulse.server fennec.pulse fennec.ddp
   fennec-mongo.bson fennec-mongo.minimongo fennec-hunt))
