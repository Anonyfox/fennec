; Manual fixtures for the fennec-hunt package itself — NOT app tests, and NOT part of
; `fennec test`. The app's own Http and Browser suites now live under test/http/ and
; test/browser/ and run via `fennec test http` / `fennec test browser`.

; TLS proof: a pure-OCaml self-signed HTTPS server (tls_server) + a hunt against it over
; https:// (tls_check). Proves fennec_hunt.Http speaks TLS. Run manually, not in `dune test`.
(executable
 (name tls_check)
 (modules tls_check)
 (libraries fennec-hunt))

(executable
 (name tls_server)
 (modules tls_server)
 (libraries eio eio_main tls tls-eio x509 ptime mirage-crypto-rng.unix))

; I/O e2e proofs (timeout, redirects, chunked) against a tiny pure-Eio probe server.
(executable
 (name probe_server)
 (modules probe_server)
 (libraries eio eio_main))

(executable
 (name probe_check)
 (modules probe_check)
 (libraries fennec-hunt))
