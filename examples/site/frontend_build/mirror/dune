; The CSR mirror of ../frontend: the SAME app + component .mlx sources compiled to
; JS via melange/reason-react. Templates are SSR-only, so they are not mirrored.
; copy_files globs *.mlx only (never the native lib's generated .ml artifacts);
; include_subdirs qualified keeps the same module paths as the native lib, so the
; shared sources compile identically. One (subdir ...) line per leaf dir — the
; only place adding a brand-new app dir touches a dune file.
(include_subdirs qualified)
(library
 (name frontend_client)
 (public_name fennec-examples.frontend_client)
 (modes melange)
 (flags (:standard -w -27-32-33-37-39))
 (libraries fennec.matcher fennec.head fennec.headkit_melange fennec.router_melange
   reason-react melange.js)
 (preprocess (pps melange.ppx reason-react-ppx)))
(subdir apps/default (copy_files (files %{project_root}/examples/site/frontend/apps/default/*.mlx)))
(subdir apps/admin (copy_files (files %{project_root}/examples/site/frontend/apps/admin/*.mlx)))
(subdir components (copy_files (files %{project_root}/examples/site/frontend/components/*.mlx)))
