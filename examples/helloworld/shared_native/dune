; SSR compile of the shared .mlx components (server-reason-react, native). The
; SAME files are compiled to JS in shared_js/. copy_files# brings them in so
; there is one source of truth in shared/.
(library
 (name app_native)
 (flags
  (:standard -w -27-32-33-37-39))
 (libraries server-reason-react.react server-reason-react.reactDom)
 (preprocess
  (pps server-reason-react.browser_ppx server-reason-react.melange_ppx server-reason-react.ppx)))

(copy_files#
 (files ../shared/*.mlx))
